    filedata = filedata.replace("__ENTITY_ID__", entity_id)
    save_data(f"{COMPONENT_PATH}/{entity_kebab}.component.ts", filedata)


def generateTablePageComponent():

    indent4 = "    "
    indent8 = "        "
    table_page_imports = []
    collections_declarations = []
    injected_services = []
    collections_init = []
    services_read = []

    for idx, key in enumerate(keys):
        if key.endswith("_enum"):
            PascalType = key.replace("_", " ").title().replace(" ", "")
            KebabType = key.replace("_", "-")
            camelType = PascalType[0].lower() + PascalType[1:]

            collection_name = f"{camelType}Collection"
            collection = f"{collection_name}: {PascalType}[] = [];"
            if len(collections_declarations):
                collections_declarations.append(indent4 + collection)
            else:
                collections_declarations.append(collection)

            table_page_imports.append(
                "import { " + PascalType + " } from " + f"'../{KebabType}/{KebabType}';"
            )
            table_page_imports.append(
                "import { "
                + PascalType
                + "Service } from "
                + f"'../{KebabType}/{KebabType}.service';"
            )

            service_name = f"{camelType}Service"
            service_inject = f"public {service_name}: {PascalType}Service,"
            if len(injected_services):
                injected_services.append(indent8 + service_inject)
            else:
                injected_services.append(service_inject)

            service_read_function = f"{camelType}Read"
            fill_collection = f"this.{service_read_function}();"
            if len(collections_init):
                collections_init.append(indent8 + fill_collection)
            else:
                collections_init.append(fill_collection)

            with open(f"{TEMPLATE_PATH}/read-function.template.ts", "r") as file:
                read_function = file.read()

            read_function = read_function.replace(
                "__SERVICE_READ_FUNCTION__", service_read_function
            )
            read_function = read_function.replace("__SERVICE_NAME__", service_name)
            read_function = read_function.replace(
                "__COLLECTION_NAME__", collection_name
            )
            read_function_coll = read_function.splitlines()

            if len(services_read):
                read_function_coll[0] = indent4 + read_function_coll[0]
                services_read.append(
                    ("\n" + indent4).join(map(str, read_function_coll)) + "\n"
                )
            else:
                services_read.append(
                    ("\n" + indent4).join(map(str, read_function_coll)) + "\n"
                )

    with open(f"{TEMPLATE_PATH}/table-page-template.component.ts", "r") as file:
        filedata = file.read()
    filedata = filedata.replace("__ENTITY_PASCAL__", entity_pascal)
    filedata = filedata.replace("__ENTITY_CAMEL__", entity_camel)
    filedata = filedata.replace("__ENTITY_KEBAB__", entity_kebab)
    filedata = filedata.replace("__ENTITY_ID__", entity_id)

    filedata = filedata.replace(
        "__TABLE_PAGE_IMPORTS__", "\n".join(map(str, table_page_imports))
    )
    filedata = filedata.replace(
        "__COLLECTIONS_DECLARATIONS__", "\n".join(map(str, collections_declarations))
    )
    filedata = filedata.replace(
        "__INJECTED_SERVICES__", "\n".join(map(str, injected_services))
    )
    filedata = filedata.replace(
        "__COLLECTIONS_INIT__", "\n".join(map(str, collections_init))
    )
    filedata = filedata.replace("__SERVICES_READ__", "\n".join(map(str, services_read)))

    save_data(f"{COMPONENT_PATH}/{entity_kebab}.component.ts", filedata)


# generate html pages
is_enum_entity = entity_snake.endswith("_enum")
