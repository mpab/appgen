    exit()

# create component folder
try:
    os.mkdir(COMPONENT_PATH)
    print(f"folder: '{COMPONENT_PATH}' created successfully.")
except FileExistsError:
    print(f"folder: '{COMPONENT_PATH}' already exists.")
except PermissionError:
