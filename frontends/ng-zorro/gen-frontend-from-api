#!/usr/bin/env python

import pandas as pd
import shutil as sh
import os.path
import sys
import requests
import json
import re

if len(sys.argv) <= 1:
    print("url required")
    exit()

entity_url = sys.argv[1]

try:
    response = requests.get(entity_url)
    response_json = response.json()
    entity_pascal = entity_url.split("/")[-1]
except Exception as e:
    print("reading url failed")
    print(f"FATAL: {e}")
    exit()


def banner(message):
    print("-" * 80)
    print(message)


entity_pascal_spaced = re.findall(r"[A-Z][^A-Z]*", entity_pascal)
entity_pascal_spaced = " ".join(entity_pascal_spaced)
entity_lower_spaced = entity_pascal_spaced.lower()
entity_snake = entity_lower_spaced.replace(" ", "_").lower()
entity_snake_ucase = entity_snake.upper()
entity_kebab = entity_snake.replace("_", "-")
entity_camel = entity_pascal[0].lower() + entity_pascal[1:]

TEMPLATE_PATH = f'{os.environ["__APPGEN_FE_PATH__"]}/templates/component'
ALERT_PATH = f'{os.environ["__APPGEN_FE_PATH__"]}/templates/alert'
FRONTEND_PATH = "./presentation"
COMPONENT_PATH = f"{FRONTEND_PATH}/src/pages/{entity_kebab}"

banner(f"component: {COMPONENT_PATH}")

expected_entity_id = entity_snake + "_id"

