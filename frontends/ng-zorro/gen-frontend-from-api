def save_data(filepath, data):
    print(f"{filepath}")
    with open(filepath, "w", newline="\n") as file:
        file.write(data)


def generateDto():
    dto = f"export interface {entity_pascal} " + "{\n"
    for idx in range(len(keys) + 1):
        if idx >= len(keys):  # terminal actions
            dto = dto + "};"
            break  # prevent out-of-bounds access
        key = keys[idx]
        if key.endswith("_id"):
            dto = dto + f"    {key}: number," + "\n"
        else:
            dto = dto + f"    {key}: string," + "\n"
    save_data(f"{COMPONENT_PATH}/{entity_kebab}.ts", dto)


def generateEnumPageHtml():

    tbl_keys = ""
    tbl_vals = ""
    create = ""
    indent = "                "

    for idx in range(len(keys) + 1):

        if idx == 0:  # skip id column
            continue

        if idx >= len(keys):  # terminal actions
            tbl_keys = tbl_keys + indent + "<th>Action</th>"
            create = (
                create
                + indent
                + '<td><button (click)="create()" [disabled]="isNullOrEmpty(newItem)">Add</button></td>'
            )
            break  # prevent out-of-bounds access

        key = keys[idx]

        # assume keys snake-cased
        column_name = key.removesuffix("_enum").replace("_", " ").title()

        tbl_key = f"<th>{column_name}</th>" + "\n"
        control = (
            f'<td><input type="text" [(ngModel)]="__ENTITY_CAMEL__Collection[idx].{key}" name="{key}_'
            + '{{idx}}" /></td>\n'
        )

        if idx == len(keys) - 1:
            tbl_keys = tbl_keys + tbl_key

            tbl_vals = tbl_vals + control
            tbl_vals = (
                tbl_vals
                + '                @if (idx < __ENTITY_CAMEL__Collection.length -1) { <td><button (click)="update(item)">Save</button>'
                + "\n"
            )
            tbl_vals = tbl_vals + "                    } @else {\n"
            tbl_vals = (
                tbl_vals
                + '                    <td><button (click)="update(item)">Save</button><nz-divider nzType="vertical"></nz-divider><button\n'
            )
            tbl_vals = (
                tbl_vals
                + '                            (click)="delete(item)">Delete</button>\n'
            )
            tbl_vals = tbl_vals + "                        }"
        else:
            tbl_keys = tbl_keys + tbl_key
            tbl_vals = tbl_vals + control

        if idx:
            create = (
                create
                + f'<td><input [(ngModel)]="newItem.{key}" name="newItem.{key}" /></td>'
                + "\n"
            )

    with open(f"{TEMPLATE_PATH}/enum-page-template.component.html", "r") as file:
        filedata = file.read()
    filedata = filedata.replace("__TBL_KEYS__", tbl_keys)
    filedata = filedata.replace("__TBL_VALS__", tbl_vals)
    filedata = filedata.replace("__CREATE__", create)
    filedata = filedata.replace("__ENTITY_PASCAL__", entity_pascal)
    filedata = filedata.replace("__ENTITY_CAMEL__", entity_camel)
    filedata = filedata.replace("__ENTITY_KEBAB__", entity_kebab)
    filedata = filedata.replace("__ENTITY_ID__", entity_id)
    save_data(f"{COMPONENT_PATH}/{entity_kebab}.component.html", filedata)


def generateTablePageHtml():

    tbl_keys = ""
    tbl_vals = ""
    create = ""
    indent = "                "

    for idx in range(len(keys) + 1):

        if idx == 0:  # skip id column
            continue

        if idx >= len(keys):  # terminal actions
            tbl_keys = tbl_keys + indent + "<th nzRight>Action</th>"
            create = (
                create
                + '<td nzRight><button (click)="create()" [disabled]="isNullOrEmpty(newItem)">Add</button></td>'
            )
            break  # prevent out-of-bounds access

        key = keys[idx]

        # assume keys snake-cased
        column_name = key.removesuffix("_enum").replace("_", " ").title()

        tbl_key = f"<th>{column_name}</th>" + "\n"

        if key.endswith("_enum"):
            with open(
                f"{TEMPLATE_PATH}/enum-control-template.component.html", "r"
            ) as file:
                control = file.read()
            create = create + control
            pascal_type = key.replace("_", " ").title().replace(" ", "")
            camel_type = pascal_type[0].lower() + pascal_type[1:]
            collection_name = f"{camel_type}Collection"
            control = control.replace("__COLLECTION_NAME__", collection_name)
            control = control.replace("__KEY__", key)
            enum_item = f"{key}_item"
            control = control.replace("__ENUM__ITEM__", enum_item)
            control_coll = control.splitlines()
            control = ("\n            ").join(map(str, control_coll)) + "\n"
            create = create.replace("__COLLECTION_NAME__", collection_name)
        else:
            control = (
                f'<td><input type="text" [(ngModel)]="__ENTITY_CAMEL__Collection[idx].{key}" name="{key}_'
                + '{{idx}}" /></td>\n'
            )
            create = (
                create
                + f'<td><input type="text" [(ngModel)]="newItem.{key}" name="newItem.{key}" /></td>\n'
            )

        create = create.replace("item.__KEY__", "newItem.__KEY__")
        create = create.replace(
            "__ENTITY_CAMEL__Collection[idx].__KEY__", "newItem.__KEY__"
        )
        create = create.replace("__KEY__{{idx}}", "newItem.__KEY__")
        create = create.replace("__ENUM__ITEM__", "item")
        create = create.replace("__KEY__", key)

        if idx == len(keys) - 1:  # last column
            tbl_keys = tbl_keys + indent + tbl_key
            tbl_vals = tbl_vals + indent + control
            tbl_vals = (
                tbl_vals
                + indent
                + '<td nzRight><button (click)="update(item)">Save</button><nz-divider nzType="vertical"></nz-divider><button\n'
            )
            tbl_vals = tbl_vals + indent + '(click)="delete(item)">Delete</button>'
            control = control.replace("<td>", "<td nzRight>")

        else:
            if idx == 1:  # first column
                tbl_keys = tbl_keys + f"<th nzLeft>{column_name}</th>" + "\n"
                control = control.replace("<td>", "<td nzLeft>")
                create = create.replace("<td>", "<td nzLeft>")
                tbl_vals = tbl_vals + control
            else:
                tbl_keys = tbl_keys + indent + tbl_key
                tbl_vals = tbl_vals + indent + control

    with open(f"{TEMPLATE_PATH}/table-page-template.component.html", "r") as file:
        filedata = file.read()
    filedata = filedata.replace("__TBL_KEYS__", tbl_keys)
    filedata = filedata.replace("__TBL_VALS__", tbl_vals)
    filedata = filedata.replace("__CREATE__", create)
    filedata = filedata.replace("__ENTITY_PASCAL__", entity_pascal)
    filedata = filedata.replace("__ENTITY_CAMEL__", entity_camel)
    filedata = filedata.replace("__ENTITY_KEBAB__", entity_kebab)
    filedata = filedata.replace("__ENTITY_ID__", entity_id)
    save_data(f"{COMPONENT_PATH}/{entity_kebab}.component.html", filedata)


def generateEnumPageComponent():
    with open(f"{TEMPLATE_PATH}/enum-page-template.component.ts", "r") as file:
        filedata = file.read()
